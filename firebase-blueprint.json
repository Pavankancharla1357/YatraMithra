{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "age": { "type": "integer" },
        "location_city": { "type": "string" },
        "location_country": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "travel_preferences": { "type": "object" },
        "bio": { "type": "string" },
        "photo_url": { "type": "string", "format": "uri" },
        "cover_url": { "type": "string", "format": "uri" },
        "reputation_score": { "type": "number" },
        "is_email_verified": { "type": "boolean" },
        "is_id_verified": { "type": "boolean" },
        "social_links": { "type": "object" },
        "vibe_quiz_results": { "type": "object" },
        "gender": { "type": "string", "enum": ["male", "female", "other", "prefer_not_to_say"] },
        "phone_number": { "type": "string" },
        "is_phone_verified": { "type": "boolean" },
        "is_verified": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name"]
    },
    "Review": {
      "title": "Peer Review",
      "description": "User rating and review after a trip",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "reviewer_id": { "type": "string" },
        "reviewee_id": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["trip_id", "reviewer_id", "reviewee_id", "rating"]
    },
    "BuddyPost": {
      "title": "Buddy Post",
      "description": "Post looking for a travel buddy",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "content": { "type": "string" },
        "location": { "type": "string" },
        "dates": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "content"]
    },
    "ItineraryItem": {
      "title": "Itinerary Item",
      "description": "Planned activity for a trip",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "time": { "type": "string" },
        "day": { "type": "integer" },
        "votes": { "type": "array", "items": { "type": "string" } },
        "votes_count": { "type": "integer" },
        "type": { "type": "string", "enum": ["activity", "dining", "transport", "lodging", "other"] },
        "created_by": { "type": "string" },
        "created_by_name": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["trip_id", "title", "day"]
    },
    "Trip": {
      "title": "Trip",
      "description": "Travel trip details",
      "type": "object",
      "properties": {
        "organizer_id": { "type": "string" },
        "starting_city": { "type": "string", "description": "City where the trip starts" },
        "starting_country": { "type": "string", "description": "Country where the trip starts" },
        "destination_city": { "type": "string" },
        "destination_country": { "type": "string" },
        "destination_lat": { "type": "number" },
        "destination_lng": { "type": "number" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "budget_max": { "type": "integer" },
        "max_members": { "type": "integer" },
        "current_members": { "type": "integer" },
        "travel_style": { "type": "string" },
        "description": { "type": "string" },
        "itinerary": { "type": "string" },
        "is_women_only": { "type": "boolean" },
        "settings": {
          "type": "object",
          "properties": {
            "privacy": { "type": "string", "enum": ["public", "private", "invite_only"] },
            "show_exact_location": { "type": "boolean" },
            "notification_preferences": {
              "type": "object",
              "properties": {
                "new_member": { "type": "boolean" },
                "new_message": { "type": "boolean" },
                "expense_update": { "type": "boolean" }
              }
            }
          }
        },
        "status": { "type": "string", "enum": ["open", "full", "ongoing", "completed", "cancelled"] },
        "invite_code": { "type": "string", "description": "Unique code for joining the trip via link" },
        "invite_count": { "type": "integer", "description": "Number of users who joined via invite link" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["organizer_id", "destination_city", "start_date", "end_date", "status"]
    },
    "TripMember": {
      "title": "Trip Member",
      "description": "Relationship between a user and a trip",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "user_photo_url": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["organizer", "member"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "left"] },
        "request_message": { "type": "string" },
        "joined_via": { "type": "string", "enum": ["request", "invite_link"] },
        "invite_token": { "type": "string" },
        "invite_code": { "type": "string" },
        "joined_at": { "type": "string", "format": "date-time" }
      },
      "required": ["trip_id", "user_id", "role", "status"]
    },
    "Channel": {
      "title": "Chat Channel",
      "description": "A chat channel between users or for a trip",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["direct", "trip"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "trip_id": { "type": "string" },
        "last_message": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "channel_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "content": { "type": "string" },
        "media_urls": { "type": "array", "items": { "type": "string" } },
        "message_type": { "type": "string", "enum": ["text", "image", "file", "system", "poll"] },
        "poll_id": { "type": "string", "description": "ID of the poll if message_type is poll" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["channel_id", "sender_id", "content", "message_type"]
    },
    "Poll": {
      "title": "Poll",
      "description": "A poll in a chat channel",
      "type": "object",
      "properties": {
        "channel_id": { "type": "string" },
        "creator_id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object", "description": "Map of userId to optionIndex" },
        "created_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["channel_id", "creator_id", "question", "options"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Trip expense",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "paid_by": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "description": { "type": "string" },
        "split_among": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["trip_id", "paid_by", "amount", "currency"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "title", "body"]
    },
    "SafetyContact": {
      "title": "Safety Contact",
      "description": "Emergency contact for a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "relationship": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name", "phone"]
    },
    "UserLocation": {
      "title": "User Location",
      "description": "Real-time location of a user during a trip",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "trip_id": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "trip_id", "latitude", "longitude"]
    },
    "ScannedDocument": {
      "title": "Scanned Document",
      "description": "Extracted data from a travel document",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "confidence": { "type": "number" },
        "summary": { "type": "string" },
        "details": { "type": "object" },
        "image_url": { "type": "string", "format": "uri" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "confidence", "summary", "details", "created_at"]
    },
    "Connection": {
      "title": "Connection",
      "description": "Connection request between two users",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "status"]
    },
    "TripInvite": {
      "title": "Trip Invite",
      "description": "Invitation to join a trip via a unique link",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "inviter_id": { "type": "string" },
        "invite_code": { "type": "string" },
        "token": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["trip_id", "inviter_id", "token"]
    },
    "ChatSettings": {
      "title": "Chat Settings",
      "description": "User-specific settings for a chat channel (pinned, muted, archived, deleted)",
      "type": "object",
      "properties": {
        "pinned": { "type": "boolean" },
        "muted": { "type": "boolean" },
        "archived": { "type": "boolean" },
        "deleted": { "type": "boolean" },
        "deleted_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/users/{userId}/safety_contacts/{contactId}": { "schema": "SafetyContact", "description": "User emergency contacts" },
    "/users/{userId}/documents/{documentId}": { "schema": "ScannedDocument", "description": "User's scanned travel documents" },
    "/users/{userId}/chat_settings/{chatId}": { "schema": "ChatSettings", "description": "User-specific chat settings" },
    "/trips/{tripId}": { "schema": "Trip", "description": "Trips" },
    "/trips/{tripId}/members/{memberId}": { "schema": "TripMember", "description": "Trip members" },
    "/trips/{tripId}/expenses/{expenseId}": { "schema": "Expense", "description": "Trip expenses" },
    "/trips/{tripId}/itinerary/{itemId}": { "schema": "ItineraryItem", "description": "Trip itinerary items" },
    "/trips/{tripId}/locations/{userId}": { "schema": "UserLocation", "description": "Real-time locations of trip members" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "User reviews" },
    "/buddy_posts/{postId}": { "schema": "BuddyPost", "description": "Travel buddy posts" },
    "/connections/{connectionId}": { "schema": "Connection", "description": "User connections" },
    "/trip_invites/{inviteId}": { "schema": "TripInvite", "description": "Trip invitation tokens" },
    "/channels/{channelId}": { "schema": "Channel", "description": "Chat channels" },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/polls/{pollId}": { "schema": "Poll", "description": "Chat polls" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" }
  }
}
